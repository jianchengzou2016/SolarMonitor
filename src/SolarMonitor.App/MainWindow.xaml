<Window x:Class="SolarMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SolarMonitor.App.ViewModels"
        mc:Ignorable="d"
        Title="SolarMonitor"
        Icon="Assets/SolarMonitorIcon.png"
        Width="1360"
        Height="860"
        MinWidth="1080"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#F4F0E8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" CornerRadius="20" Background="#14342B">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#F7F1E6" Text="SolarMonitor" />
                    <TextBlock Margin="0,6,0,0" FontSize="14" Foreground="#C6D6CD" Text="{Binding Texts[AppDescription]}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="#A9C4B6" Text="{Binding Texts[ConnectionStatus]}" />
                    <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#F7F1E6" Text="{Binding StatusMessage}" />
                </StackPanel>
                <Border Grid.Column="2" Margin="18,0,0,0" Padding="14,10" VerticalAlignment="Center" CornerRadius="14" Background="#254F43">
                    <StackPanel>
                        <TextBlock Foreground="#A9C4B6" FontSize="12" Text="{Binding Texts[LastRefresh]}" />
                        <TextBlock Foreground="#F7F1E6" FontSize="15" FontWeight="SemiBold" Text="{Binding LastUpdatedText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,16,0,16" Padding="18" CornerRadius="18" Background="#E6DDD0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,6" FontWeight="SemiBold" Text="{Binding Texts[ApiKey]}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Margin="16,0,0,6" FontWeight="SemiBold" Text="{Binding Texts[InverterSerialNumber]}" />
                <TextBlock Grid.Row="0" Grid.Column="5" Margin="12,0,0,6" FontWeight="SemiBold" Text="{Binding Texts[Language]}" />
                <TextBox Grid.Row="1" Grid.Column="0" Height="36" Padding="10,6" VerticalContentAlignment="Center" Background="#FFFDF8" BorderBrush="#C9BFAF" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="16,0,0,0" Height="36" Padding="10,6" VerticalContentAlignment="Center" Background="#FFFDF8" BorderBrush="#C9BFAF" Text="{Binding InverterSerialNumber, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Grid.Column="2" Margin="16,0,0,0" Padding="18,8" Click="LoadDevices_Click" Content="{Binding Texts[LoadDevices]}" />
                <Button Grid.Row="1" Grid.Column="3" Margin="12,0,0,0" Padding="18,8" Click="LoadDetail_Click" Content="{Binding Texts[LoadDetail]}" />
                <Button Grid.Row="1" Grid.Column="4" Margin="12,0,0,0" Padding="18,8" Click="LoadRealtime_Click" Content="{Binding Texts[LoadRealtime]}" />
                <ComboBox Grid.Row="1" Grid.Column="5" Margin="12,0,0,0" Width="118" Height="36"
                          ItemsSource="{Binding LanguageOptions}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Code"
                          SelectedValue="{Binding LanguageCode, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.72*" />
                <ColumnDefinition Width="2.48*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.9*" />
                    <RowDefinition Height="1.1*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Margin="0,0,0,12" Padding="16" CornerRadius="18" Background="#FFFDF8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[Devices]}" />
                        <ListView Grid.Row="1" Margin="0,14,0,0" ItemsSource="{Binding Devices}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="160" Header="Serial" DisplayMemberBinding="{Binding DeviceSerialNumber}" />
                                    <GridViewColumn Width="95" Header="Model" DisplayMemberBinding="{Binding DeviceModel}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Padding="16" CornerRadius="18" Background="#FFFDF8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[DeviceDetail]}" />
                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock TextWrapping="Wrap" Text="{Binding DetailSummaryText}" />
                            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding DetailFunctionsText}" />
                        </StackPanel>
                        <ListView Grid.Row="2" Margin="0,14,0,0" ItemsSource="{Binding Batteries}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="128" Header="Battery SN" DisplayMemberBinding="{Binding BatterySerialNumber}" />
                                    <GridViewColumn Width="52" Header="Type" DisplayMemberBinding="{Binding Type}" />
                                    <GridViewColumn Width="76" Header="Model" DisplayMemberBinding="{Binding Model}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="#FFFDF8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.4*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[RealtimeDashboard]}" />
                            <TextBlock Margin="0,4,0,0" Foreground="#5E6B63" Text="{Binding RealtimeObservedText}" />
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  Margin="16,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding IsAutoRefreshEnabled}"
                                  Checked="RefreshToggle_Changed"
                                  Unchecked="RefreshToggle_Changed"
                                  Content="{Binding Texts[AutoRefresh]}" />
                        <ComboBox Grid.Column="2"
                                  Margin="12,0,0,0"
                                  Width="120"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding RefreshIntervals}"
                                  SelectedItem="{Binding SelectedRefreshInterval}"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="RefreshInterval_SelectionChanged" />
                    </Grid>

                    <UniformGrid Grid.Row="1" Margin="0,16,0,0" Columns="4">
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#F3F7F1">
                            <StackPanel>
                                <TextBlock Foreground="#4D6B58" Text="{Binding Texts[BatterySoc]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding BatterySocText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#F6F1EA">
                            <StackPanel>
                                <TextBlock Foreground="#7A6040" Text="{Binding Texts[BatteryTemp]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding BatteryTemperatureText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#EEF5F8">
                            <StackPanel>
                                <TextBlock Foreground="#476C7A" Text="{Binding Texts[BatterySoh]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding BatterySohText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#FBF1E5">
                            <StackPanel>
                                <TextBlock Foreground="#8B673E" Text="{Binding Texts[InverterFinTemperature]}"/>
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding InverterFinTemperatureText}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#FBF1E5">
                            <StackPanel>
                                <TextBlock Foreground="#8B673E" Text="{Binding Texts[InverterCoreTemperature]}"/>
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding InverterCoreTemperatureText}"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#F8F0F0">
                            <StackPanel>
                                <TextBlock Foreground="#7F5757" Text="{Binding Texts[BatteryDischarge]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding BatteryDischargeText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#EEF6EA">
                            <StackPanel>
                                <TextBlock Foreground="#5B7647" Text="{Binding Texts[HomeUsage]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding HomeUsageText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#ECF4FB">
                            <StackPanel>
                                <TextBlock Foreground="#4A6786" Text="{Binding Texts[DerivedPvOutput]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding PvGeneratedText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#FBF1E5">
                            <StackPanel>
                                <TextBlock Foreground="#8B673E" Text="{Binding Texts[GridImport]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding GridImportText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#F3ECFA">
                            <StackPanel>
                                <TextBlock Foreground="#65507F" Text="{Binding Texts[GridExport]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding GridExportText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,10,10" Padding="12" CornerRadius="14" Background="#F3ECFA">
                            <StackPanel>
                                <TextBlock Foreground="#65507F" Text="{Binding Texts[TotalGridExport]}" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding GridTotalExportText}" />
                            </StackPanel>
                        </Border>                        
                    </UniformGrid>

                    <Border Grid.Row="2" Margin="0,16,0,0" Padding="14" CornerRadius="16" Background="#FAF7F1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[RecentTrend]}" />
                            <ScrollViewer x:Name="TrendScrollViewer"
                                          Grid.Row="1"
                                          Margin="0,14,0,0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          CanContentScroll="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="{Binding ChartCanvasWidth}" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="{Binding ChartCanvasHeight}" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Canvas Grid.Row="0" Grid.Column="0" Height="{Binding ChartCanvasHeight}">
                                        <ItemsControl ItemsSource="{Binding YAxisTicks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ChartAxisTick}">
                                                    <TextBlock Width="58"
                                                               Foreground="#6D665E"
                                                               Margin="0,-8,0,0"
                                                               Text="{Binding Label}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                    <Canvas Grid.Row="0"
                                            Grid.Column="1"
                                            x:Name="TrendChartCanvas"
                                            Width="{Binding ChartCanvasWidth}"
                                            Height="{Binding ChartCanvasHeight}"
                                            ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding YAxisTicks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ChartAxisTick}">
                                                    <Border Width="{Binding DataContext.ChartCanvasWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            BorderBrush="#E3DBCF"
                                                            BorderThickness="0,0,0,1" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding HomeUsageTrendSegments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                    <Setter Property="Canvas.Top" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Polyline Stroke="#5B7647" StrokeThickness="3" Points="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding DerivedPvTrendSegments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                    <Setter Property="Canvas.Top" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Polyline Stroke="#4A6786" StrokeThickness="3" Points="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding GridImportTrendSegments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                    <Setter Property="Canvas.Top" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Polyline Stroke="#8B673E" StrokeThickness="3" Points="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl ItemsSource="{Binding GridExportTrendSegments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="0" />
                                                    <Setter Property="Canvas.Top" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Polyline Stroke="#65507F" StrokeThickness="3" Points="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Line x:Name="TrendHoverGuide"
                                              Visibility="Collapsed"
                                              Stroke="#9A9186"
                                              StrokeThickness="1"
                                              StrokeDashArray="3 3"
                                              Y1="0"
                                              Y2="{Binding ChartCanvasHeight}" />
                                        <Border x:Name="TrendHoverCard"
                                                Visibility="Collapsed"
                                                Padding="10,8"
                                                CornerRadius="12"
                                                Background="#FDFBF6"
                                                BorderBrush="#CFC4B4"
                                                BorderThickness="1">
                                            <TextBlock x:Name="TrendHoverText"
                                                       Foreground="#14342B"
                                                       FontSize="12"
                                                       LineHeight="18" />
                                        </Border>
                                        <Rectangle Width="{Binding ChartCanvasWidth}"
                                                   Height="{Binding ChartCanvasHeight}"
                                                   Fill="Transparent"
                                                   MouseMove="TrendChartOverlay_MouseMove"
                                                   MouseLeave="TrendChartOverlay_MouseLeave" />
                                    </Canvas>
                                    <Grid Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,10,0,0"
                                          Width="{Binding ChartCanvasWidth}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Left" Foreground="#6D665E" Text="{Binding TimeAxisStartLabel}" />
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="#6D665E" Text="{Binding TimeAxisMiddleLabel}" />
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="#6D665E" Text="{Binding TimeAxisEndLabel}" />
                                    </Grid>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.92*" />
                            <ColumnDefinition Width="1.08*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,12,0" Padding="14" CornerRadius="16" Background="#FAF7F1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[RecentRefreshes]}" />
                                <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding TrendSamples}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="68" Header="Time" DisplayMemberBinding="{Binding TimestampText}" />
                                            <GridViewColumn Width="72" Header="Home" DisplayMemberBinding="{Binding HomeUsagePower}" />
                                            <GridViewColumn Width="72" Header="Der. PV" DisplayMemberBinding="{Binding DerivedPvOutputPower}" />
                                            <GridViewColumn Width="72" Header="Import" DisplayMemberBinding="{Binding GridImportPower}" />
                                            <GridViewColumn Width="72" Header="Export" DisplayMemberBinding="{Binding GridExportPower}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Padding="14" CornerRadius="16" Background="#FAF7F1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="SemiBold" Foreground="#14342B" Text="{Binding Texts[AllRealtimeMetrics]}" />
                                <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding RealtimeMetrics}">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="120" Header="Variable" DisplayMemberBinding="{Binding Variable}" />
                                            <GridViewColumn Width="140" Header="Name" DisplayMemberBinding="{Binding DisplayName}" />
                                            <GridViewColumn Width="85" Header="Value" DisplayMemberBinding="{Binding ValueText}" />
                                            <GridViewColumn Width="65" Header="Unit" DisplayMemberBinding="{Binding Unit}" />
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,16,0,0" Padding="14,10" CornerRadius="14" Background="#E6DDD0">
            <TextBlock Text="{Binding FooterText}" />
        </Border>
    </Grid>
</Window>
